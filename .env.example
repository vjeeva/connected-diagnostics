ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/diagnostics

# LLM providers: anthropic, openai, google
EXTRACTION_PROVIDER=anthropic
EXTRACTION_MODEL=claude-haiku-4-5-20251001
CHAT_PROVIDER=anthropic
CHAT_MODEL=claude-sonnet-4-20250514          # strong: open-ended, work orders, no graph match
CHAT_MODEL_LIGHT=claude-haiku-4-5-20251001   # cheap: graph traversal, known procedures
VISION_PROVIDER=anthropic
VISION_MODEL=claude-haiku-4-5-20251001

# Embedding providers: openai, google
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

INGESTION_WORKERS=8
CHUNK_MAX_CHARS=16000
CHUNK_OVERLAP_PAGES=2
